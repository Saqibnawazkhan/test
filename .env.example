# ===== TaxNet AI — environment template =====
# Copy to .env and fill in. .env is git-ignored.

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx   # safe in the Flutter app (with RLS)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx             # BACKEND ONLY — never ship to the app
# Postgres direct connection (Settings -> Database -> Connection string -> URI):
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# --- LLM (Claude) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- Payments (Stripe test for demo; swap later) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
